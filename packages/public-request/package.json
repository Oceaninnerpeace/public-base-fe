{
  "name": "@Oceaninnerpeace/public-base-request",
  "version": "0.1.0",
  "description": "公共 Axios 封装（工厂模式，供基座与子应用各自 createRequest）",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Oceaninnerpeace/public-base-fe.git",
    "directory": "packages/public-request"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build",
    "prepublishOnly": "pnpm run build && node ./scripts/prepare-publish-exports.mjs",
    "postpublish": "node ./scripts/restore-dev-exports.mjs"
  },
  "peerDependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "axios": "^1.7.9",
    "typescript": "~5.7.2",
    "vite": "^6.0.11",
    "vite-plugin-dts": "^4.5.0"
  }
}
